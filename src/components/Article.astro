---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<article class="article">
  <header class="article-header">
    <h1>{title}</h1>
  </header>
  <div class="article-body">
    <slot />
  </div>
</article>

<style>
  .article {
    max-width: 100%;
  }

  .article-header {
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-sm);
  }

  .article-header h1 {
    margin: 0 0 0.5rem 0;
    font-size: 2.4rem;
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--text-color);
    padding-bottom: 0.75rem;
    border-bottom: 3px solid var(--accent-color);
    display: inline-block;
  }

  .article-body {
    line-height: var(--line-height-base);
  }

  .article-body :global(h2) {
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 1.5rem 0;
    letter-spacing: -0.02em;
    padding-bottom: 0.75rem;
    border-bottom: 3px solid var(--accent-color);
    display: inline-block;
  }

  .article-body :global(p) {
    margin: 0 0 1.5rem 0;
  }

  .article-body :global(figure.image-right) {
    float: right;
    margin: 0 0 1rem 1.5rem;
    max-width: 300px;
  }

  .article-body :global(figure.image-left) {
    float: left;
    margin: 0 1.5rem 1rem 0;
    max-width: 300px;
  }

  .article-body :global(figure img) {
    max-width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 600px) {
    .article-body :global(figure.image-right),
    .article-body :global(figure.image-left) {
      float: none;
      margin: 1rem 0;
      max-width: 100%;
    }
  }
</style>
