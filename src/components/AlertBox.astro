---
interface Alert {
  title?: string;
  style?: 'default' | 'christmas' | 'urgent';
}

interface Props {
  alert: Alert;
}

const { alert } = Astro.props;
const dismissKey = `alert-dismissed-global`;
---

{
  alert && (
    <div
      class={`alert-box alert-${alert.style || 'default'}`}
      role="alert"
      data-dismiss-key={dismissKey}
    >
      <button class="alert-close" aria-label="Dismiss alert" type="button">
        &times;
      </button>
      {alert.title && <h2 class="alert-title">{alert.title}</h2>}
      <div class="alert-content">
        <slot />
      </div>
    </div>
  )
}

<style>
  .alert-box {
    background-color: var(--alert-bg-color);
    padding: 1.5rem;
    margin-bottom: 2.5rem;
    border-radius: 4px;
    border-left: 4px solid var(--accent-color);
    position: relative;
  }

  .alert-urgent {
    background: #fee;
    border: 2px solid #c00;
  }

  .alert-christmas {
    background: var(--accent-muted);
    border: 1px solid var(--accent-dark);
  }

  .alert-title {
    display: block;
    margin: 0 0 0.5rem 0;
    font-size: 1.6rem;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .alert-content :global(p) {
    margin: 0;
    line-height: 1.4;
  }

  .alert-close {
    position: absolute;
    top: var(--space-sm);
    right: var(--space-sm);
    background: transparent;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: var(--text-color);
    padding: 0 var(--space-xs);
    line-height: 1;
  }

  .alert-close:hover,
  .alert-close:focus {
    color: var(--text-color);
    opacity: 0.7;
  }

  .alert-close:focus {
    outline: 2px solid var(--link-color);
    outline-offset: 2px;
  }
</style>

<script>
  document.querySelectorAll('.alert-box').forEach((alertBox) => {
    const dismissKey = alertBox.getAttribute('data-dismiss-key');

    if (dismissKey && sessionStorage.getItem(dismissKey) === 'true') {
      alertBox.remove();
      return;
    }

    const closeBtn = alertBox.querySelector('.alert-close');
    closeBtn?.addEventListener('click', () => {
      if (dismissKey) {
        sessionStorage.setItem(dismissKey, 'true');
      }
      alertBox.remove();
    });
  });
</script>
