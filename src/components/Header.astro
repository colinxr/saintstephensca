---
import type { SiteSettings } from '../lib/types';
import { urlFor } from '../lib/sanity';

interface Props {
  settings?: SiteSettings;
}

const { settings } = Astro.props;

// Default values if settings not provided
const DEFAULT_ADDRESS = '103 Bellevue Ave, Toronto, ON M5T 2N8';
const DEFAULT_DIOCESE_LINK = 'https://www.toronto.anglican.ca';

// Build the header background image URL from Sanity
let headerImageUrl: string | null = null;

if (settings?.headerImage?.asset?._ref) {
  headerImageUrl = urlFor(settings.headerImage).url();
}

// Get address and diocese link with fallbacks
const address = settings?.address || DEFAULT_ADDRESS;
const diocesanLink = settings?.diocesanLink || DEFAULT_DIOCESE_LINK;

// Create the background style with gradient overlay
const headerStyle = headerImageUrl
  ? `background: linear-gradient(to top, rgba(43, 37, 0, 0.85) 0%, rgba(43, 37, 0, 0) 100%), url("${headerImageUrl}") center center no-repeat; background-size: cover;`
  : '';
---

<header role="banner" class="site-header" style={headerStyle}>
  <div id="site-branding">
    <h1>
      <a href="/">Church of Saint Stephen-in-the-Fields</a>
    </h1>
  </div>
</header>

<div class="address-bar">
  <span class="progress-flag" aria-label="Progress Pride Flag" title="LGBTQ+ Affirming">
    <svg
      width="24"
      height="16"
      viewBox="0 0 24 16"
      xmlns="http://www.w3.org/2000/svg"
      role="img"
      aria-label="Progress Pride Flag"
    >
      <!-- Rainbow stripes -->
      <rect width="24" height="2.29" fill="#E40303"></rect>
      <rect y="2.29" width="24" height="2.29" fill="#FF8C00"></rect>
      <rect y="4.57" width="24" height="2.29" fill="#FFED00"></rect>
      <rect y="6.86" width="24" height="2.29" fill="#008026"></rect>
      <rect y="9.14" width="24" height="2.29" fill="#24408E"></rect>
      <rect y="11.43" width="24" height="2.29" fill="#732982"></rect>
      <rect y="13.71" width="24" height="2.29" fill="#613915"></rect>
      <!-- Progress chevron -->
      <polygon points="0,0 8,8 0,16" fill="#000"></polygon>
      <polygon points="0,0.5 7.5,8 0,15.5" fill="#613915"></polygon>
      <polygon points="0,1 7,8 0,15" fill="#74D7EE"></polygon>
      <polygon points="0,1.5 6.5,8 0,14.5" fill="#FFACB8"></polygon>
      <polygon points="0,2 6,8 0,14" fill="#fff"></polygon>
    </svg>
  </span>
  <span>{address}</span>
  <span class="sep">|</span>
  <a href={diocesanLink} class="diocese-link">Anglican Diocese of Toronto</a>
</div>
