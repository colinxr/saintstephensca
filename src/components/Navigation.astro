---
import type { NavigationItem as NavigationItemType } from '../lib/types';
import NavigationItem from './NavigationItem.astro';
import '../styles/navigation.css';

interface Props {
  items: NavigationItemType[];
}

const { items = [] } = Astro.props;
const currentPath = Astro.url.pathname;
---

<nav role="navigation" aria-label="Main navigation">
  <button
    class="menu-toggle"
    aria-expanded="false"
    aria-controls="main-menu"
    aria-label="Toggle navigation menu"
  >
    <span aria-hidden="true">Menu</span>
  </button>
  <ul id="main-menu" class="menu">
    {items?.map((item) => <NavigationItem item={item} currentPath={currentPath} />)}
  </ul>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const menuToggle = document.querySelector('.menu-toggle');
    const mainMenu = document.getElementById('main-menu');

    // Toggle mobile menu
    if (menuToggle && mainMenu) {
      menuToggle.addEventListener('click', () => {
        const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
        menuToggle.setAttribute('aria-expanded', String(!isExpanded));
        mainMenu.classList.toggle('open');
      });
    }

    // Handle all menu items with submenus recursively
    const setupMenuItem = (item: Element) => {
      const link = item.querySelector(':scope > a');
      const submenu = item.querySelector(':scope > ul');

      if (submenu && link) {
        // Keyboard navigation for this menu item
        link.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'ArrowDown') {
            e.preventDefault();
            (submenu as HTMLElement).style.display = 'block';
            link.setAttribute('aria-expanded', 'true');
            const firstSubmenuLink = submenu.querySelector('a');
            if (firstSubmenuLink) {
              (firstSubmenuLink as HTMLElement).focus();
            }
          }
          if (e.key === 'Escape') {
            (submenu as HTMLElement).style.display = 'none';
            link.setAttribute('aria-expanded', 'false');
            (link as HTMLElement).focus();
          }
        });

        // Show submenu on focus
        link.addEventListener('focus', () => {
          (submenu as HTMLElement).style.display = 'block';
          link.setAttribute('aria-expanded', 'true');
        });

        // Handle submenu keyboard navigation
        submenu.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'Escape') {
            (submenu as HTMLElement).style.display = 'none';
            link.setAttribute('aria-expanded', 'false');
            (link as HTMLElement).focus();
          }
        });

        // Arrow navigation within submenu
        const submenuLinks = Array.from(submenu.querySelectorAll(':scope > li > a'));
        submenuLinks.forEach((submenuLink, index) => {
          submenuLink.addEventListener('keydown', (e: KeyboardEvent) => {
            if (e.key === 'ArrowDown') {
              e.preventDefault();
              const nextLink = submenuLinks[index + 1];
              if (nextLink) {
                (nextLink as HTMLElement).focus();
              }
            }
            if (e.key === 'ArrowUp') {
              e.preventDefault();
              if (index === 0) {
                (link as HTMLElement).focus();
              } else {
                const prevLink = submenuLinks[index - 1];
                if (prevLink) {
                  (prevLink as HTMLElement).focus();
                }
              }
            }
          });
        });

        // Recursively setup nested menu items
        const nestedItems = submenu.querySelectorAll(':scope > li');
        nestedItems.forEach(setupMenuItem);
      }
    };

    // Setup all top-level menu items
    const topLevelItems = mainMenu?.querySelectorAll(':scope > li') || [];
    topLevelItems.forEach(setupMenuItem);
  });
</script>
