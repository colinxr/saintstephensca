---
import PageLayout from '../layouts/PageLayout.astro';
import Article from '../components/Article.astro';
import Sidebar from '../components/Sidebar.astro';
import { getSiteSettings, getHomePage } from '../lib/sanity';
import { renderPortableText } from '../lib/portable-text';
import '../styles/typography.css';
import '../styles/content.css';

const settings = await getSiteSettings();
const page = await getHomePage();
---

{
  settings && page && (
    <PageLayout title={settings.churchName} settings={settings}>
      <div class="page-content">
        <div class="main-wrapper">
          <Article title={page.title}>
            <Fragment set:html={renderPortableText(page.mainContent)} />
          </Article>
        </div>

        <Sidebar widgets={page.sidebarWidgets} settings={settings} />
      </div>
    </PageLayout>
  )
}

{
  (!settings || !page) && (
    <PageLayout
      title="Welcome"
      settings={{
        churchName: 'Saint Stephen-in-the-Fields',
        address: 'Kensington Market, Toronto',
        footerCopyright: '© 2026 Saint Stephen-in-the-Fields',
        socialLinks: [],
        mainNavigation: {
          _id: 'default',
          title: 'Main Navigation',
          items: [
            { label: 'Home', link: '/' },
            { label: 'Contact', link: '/contact' },
          ],
        },
      }}
    >
      <div class="page-content">
        <div class="main-wrapper">
          <Article title="Welcome">
            <p>Welcome to our church website. Content coming soon.</p>
          </Article>
        </div>
      </div>
    </PageLayout>
  )
}

<style>
  .page-content {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 3rem;
    max-width: 960px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem;
  }

  .main-wrapper {
    min-width: 0;
  }

  @media (max-width: 900px) {
    .page-content {
      grid-template-columns: 1fr;
    }
  }
</style>
