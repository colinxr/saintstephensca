---
export const prerender = false;

import PageLayout from '../layouts/PageLayout.astro';
import AlertBox from '../components/AlertBox.astro';
import Article from '../components/Article.astro';
import Sidebar from '../components/Sidebar.astro';
import { getSiteSettings, getPageBySlug } from '../lib/sanity';
import { renderPortableText } from '../lib/portable-text';
import '../styles/typography.css';
import '../styles/content.css';

const settings = await getSiteSettings();

// Build the slug from the array parameter
const slugArray = Astro.params.slug;
const slug = Array.isArray(slugArray) ? slugArray.join('/') : slugArray;

const page = await getPageBySlug(slug);

// If no page found, return 404
if (!page) {
  return Astro.redirect('/404');
}
---

<PageLayout title={page.title} settings={settings}>
  <div class="page-content">
    <div class="main-wrapper">
      {page.alertBox?.show && <AlertBox alert={page.alertBox} pageSlug={page.slug?.current} />}

      <Article title={page.title}>
        <Fragment set:html={renderPortableText(page.mainContent)} />
      </Article>
    </div>

    <Sidebar widgets={page.sidebarWidgets} settings={settings} />
  </div>
</PageLayout>

<style>
  .page-content {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: var(--space-xl);
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md);
  }

  .main-wrapper {
    min-width: 0;
  }

  @media (max-width: 900px) {
    .page-content {
      grid-template-columns: 1fr;
    }
  }
</style>
